# NVIDIA NIMs API key
# Get yours at: https://ngc.nvidia.com/setup/api-key
# Make sure "AI Foundation Models and Endpoints" is selected under Services Included
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the model (default: meta/llama-3.1-8b-instruct)
# NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Optional: override the API base URL (default: https://integrate.api.nvidia.com/v1/chat/completions)
# NVIDIA_BASE_URL=http://localhost:8000/v1/chat/completions
